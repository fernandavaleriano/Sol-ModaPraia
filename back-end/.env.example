# Porta do Servidor
PORT=3000

# Google Auth (Crie um projeto em console.cloud.google.com)
GOOGLE_CLIENT_ID=SEU_CLIENT_ID_AQUI

# Senha secreta para o Token JWT (pode ser qualquer texto longo)
JWT_SECRET=chave_super_secreta_123456

# Senha para acessar o Painel Admin
ADMIN_SENHA=admin123

# URL do frontend usada no CORS.
# Em desenvolvimento pode ficar localhost; em produção troque pela URL real do site.
FRONTEND_URL=http://localhost:5500

# URL pública/base do site usada em retornos de pagamento.
# Deixe localhost enquanto estiver desenvolvendo e troque quando hospedar.
PUBLIC_SITE_URL=http://127.0.0.1:5500/front-end

# Mercado Pago Checkout Pro
# Opcional nesta fase. Preencha só quando o cliente final decidir usar Mercado Pago.
# Se o cliente escolher outra forma de pagamento, essas chaves podem continuar vazias.
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
